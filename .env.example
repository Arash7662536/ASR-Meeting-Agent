# ── Copy this file to .env and fill in your values ───────────────────────────
# The app loads this automatically via python-dotenv.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Hugging Face token — required for pyannote diarization.
# Free token at: https://huggingface.co/settings/tokens
# Accept model conditions at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=hf_your_token_here

# ─────────────────────────────────────────────────────────────────────────────
# vLLM — Whisper inference server (must be running before the app starts)
# See docs/VLLM_SETUP.md for setup instructions.
# Start with:  bash docs/start_vllm.sh
# ─────────────────────────────────────────────────────────────────────────────
VLLM_URL=http://localhost:8001/v1       # Full base URL including /v1
VLLM_MODEL=openai/whisper-large-v3     # Must match the model vLLM was started with
VLLM_API_KEY=dummy                     # vLLM doesn't enforce auth; any value works
VLLM_PORT=8001                         # Used by docs/start_vllm.sh
VLLM_GPU_UTIL=0.40                     # Fraction of GPU VRAM for vLLM (rest for pyannote etc.)
VLLM_DTYPE=bfloat16                    # bfloat16 | float16 | float32

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────────────────────────────────────

# Data storage
DATA_DIR=data

# Gradio server
HOST=0.0.0.0
PORT=7860
SHARE=true          # false = no public tunnel (use direct IP instead)

# Model defaults (UI labels / Demucs selection)
WHISPER_MODEL=large-v3          # Displayed in UI only — actual model served by vLLM
DEMUCS_MODEL=htdemucs           # htdemucs | htdemucs_ft | mdx_extra

# Pipeline behaviour
SAVE_AUDIO_CHUNKS=true          # Save per-chunk WAVs to data/output/session_*/chunks/
