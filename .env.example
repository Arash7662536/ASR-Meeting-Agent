# ── Copy this file to .env and fill in your values ───────────────────────────
# The app loads this automatically via python-dotenv.

# ── Required ──────────────────────────────────────────────────────────────────
# Hugging Face token — required for pyannote diarization.
# Free token at: https://huggingface.co/settings/tokens
# Accept model conditions at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=hf_your_token_here

# ── Paths (optional, defaults shown) ─────────────────────────────────────────
DATA_DIR=data
# OUTPUT_DIR is data/output, DB_PATH is data/meeting_transcription.db

# ── Gradio server ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=7860
SHARE=true    # Set to false to disable the public tunnel

# ── Model defaults ────────────────────────────────────────────────────────────
WHISPER_MODEL=large-v3          # large-v3 | large-v2 | medium | small | base | tiny
DEMUCS_MODEL=htdemucs           # htdemucs | htdemucs_ft | mdx_extra

# ── Pipeline behaviour ────────────────────────────────────────────────────────
SAVE_AUDIO_CHUNKS=true          # Save per-chunk WAV files to data/output/session_*/chunks/
